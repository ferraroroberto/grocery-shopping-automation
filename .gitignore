# virtual environment
.venv/

# environment / secrets
.env

# local runtime config (seeded from src/config.example.json on first run)
src/config.json

# python cache
__pycache__/
*.py[cod]
*$py.class

# logs
*.log

# user's private inventory file (keep the example xlsx)
data/list.xlsx

# audio audit runtime artefacts
audio_audit_logs/
tests/smoke_phase2_result.json

# cart-automation purchase logs (what was actually ordered, per run)
purchase_logs/

# generated SSL certificates (run gen_ssl_cert.py to recreate)
certificates/

# FastAPI webapp runtime state / secrets
config/webapp_config.json

# Telegram notifier credentials
config/notify_config.json

# Gmail OAuth client/token (read-only gmail.readonly scope)
auth/gmail/

# Gmail whitelist config + processed-message state
config/gmail_config.json
config/gmail_processed_state.json
webapp/cloudflared.yml
webapp/last_tunnel_url.txt
webapp/auth.log
webapp/certificates/

# browser automation Chrome profile — session data, never commit
automation/chrome_user_data/

# IDE / editor
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Claude Code launcher scratch (screenshot uploads, transient run files)
.launcher-tmp/
