# virtual environment
.venv/

# environment / secrets
.env

# local runtime config (seeded from src/config.example.json on first run)
src/config.json

# python cache
__pycache__/
*.py[cod]
*$py.class

# logs
*.log

# user's private inventory file (keep the example xlsx)
data/list.xlsx

# audio audit runtime artefacts
audio_audit_logs/
tests/smoke_phase2_result.json

# generated SSL certificates (run gen_ssl_cert.py to recreate)
certificates/

# browser automation session cookies (never commit)
automation/cookies/

# IDE / editor
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock
