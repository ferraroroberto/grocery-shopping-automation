%% docs/architecture.mmd — this repo's own internal structure.
%% Hand-authored, not generated — unlike a fleet-wide crawled map, this
%% repo's own internal shape is semantic and can't be scraped the same way.
%% Update this diagram in the same PR as any material structural change (a
%% new mode/route, a module moved, a new external dependency wired in) —
%% same anti-staleness contract as this repo's own `.fleet.toml` `description`
%% field. See ferraroroberto/fleet-config#256 for the general convention.

flowchart TB
  subgraph frontend["Primary surface — FastAPI + vanilla-JS PWA (:8502)"]
    STATIC["app/static/\nindex.html · app.js"]
    API["app/api.py\nroutes: inventory, items, export, automation,\naudio/* (session, chunk, events, finish, retranscribe, match, apply)"]
    MW["app/middleware.py\nBearerTokenMiddleware"]
    RUNNER["app/automation_runner.py\nstreams automation.run_automation subprocess into the app"]
    VERSIONING["src/static_versioning.py\nCachingStaticFiles: JS import hash-stamping, build identity"]
    STATIC --> API
    MW --> API
    API --> RUNNER
    API --> VERSIONING
  end

  subgraph legacy["Legacy surface — Streamlit (:8501)"]
    APPPY["app/app.py\npage config, session state, sidebar routing"]
    MODES["audit.py · audio_audit.py · edit_targets.py ·\nedit_item.py · add_item.py · shopping.py · export.py"]
    UIHELP["app/ui_helpers.py\nshared CSS + widgets"]
    APPPY --> MODES
    MODES --> UIHELP
    MODES --> RUNNER
  end

  subgraph datalayer["src/ — UI-free data & business layer"]
    DATA["src/data.py\nconfig load, XLSX read/write,\nsupermarket stats, quantity mutators"]
    AUDIOCORE["src/audio_audit_core.py\ntranscript cleaning, audit-log writer"]
    EXTRACT["src/inventory_extract.py\nLLM match against inventory"]
    TRANSCRIBE["src/transcribe_client.py\nwhisper-server client + ffmpeg transcode"]
    NET["src/net.py\nLAN-IP / port-probe helpers"]
    WEBCFG["src/webapp_config.py\ntoken/password remote-access config"]
    SSL["src/gen_ssl_cert.py\nlocal CA + server cert"]
  end
  API --> DATA
  API --> AUDIOCORE
  API --> EXTRACT
  API --> TRANSCRIBE
  API --> NET
  API --> WEBCFG
  MODES --> DATA
  MODES --> AUDIOCORE
  MODES --> EXTRACT
  MODES --> TRANSCRIBE
  MODES --> NET
  AUDIOCORE --> DATA

  XLSX[("data/list.xlsx\n(Excel-backed inventory)")]
  DATA --> XLSX

  subgraph cartauto["automation/ — Playwright cart automation"]
    RUNAUTO["run_automation.py\nCLI entrypoint"]
    STOREMODS["mercadona.py · ametller.py\nper-store cart handlers"]
    BROWSER["browser.py\nreal-Chrome launch, dedicated chrome_user_data/ profile"]
    BOOTSTRAP["bootstrap_session.py\none-time interactive store login"]
    READER["grocery_reader.py\nreads shopping-list rows from the inventory"]
    REPORT["report.py / models.py / errors.py\nrun summary, CartItem, typed exceptions"]
    RUNAUTO --> STOREMODS
    STOREMODS --> BROWSER
    BOOTSTRAP --> BROWSER
    RUNAUTO --> READER
    RUNAUTO --> REPORT
  end
  RUNNER --> RUNAUTO
  READER --> XLSX

  subgraph external["External dependencies (sibling projects, same machine)"]
    HUB["claude-local-calls hub\n127.0.0.1:8000 — Anthropic-shape LLM proxy"]
    WHISPER["whisper-server\n127.0.0.1:8090 — OpenAI-compatible transcription"]
    VOICET["voice-transcriber webapp\n127.0.0.1:8443 — chunked recording/session API"]
    CHROME["Real installed Chrome\n(not bundled Chromium)"]
    CLOUDFLARE["cloudflared named tunnel\n(webapp/cloudflared.yml)"]
  end
  EXTRACT -->|Anthropic SDK, base_url| HUB
  TRANSCRIBE -->|POST /v1/audio/transcriptions| WHISPER
  API -->|proxies recording lifecycle| VOICET
  BROWSER --> CHROME
  API -.->|optional public access| CLOUDFLARE

  subgraph scripts["scripts/ & webapp/ — setup & remote access"]
    GENTOKEN["gen_token.py / set_password.py\nbearer-token + password auth"]
    TAILCERT["gen_tailscale_cert.py\nTailscale HTTPS cert"]
    TUNNEL["run_named_tunnel.py"]
  end
  GENTOKEN --> WEBCFG
  TAILCERT --> SSL

  subgraph tests["tests/ — pytest suite + smoke scripts"]
    TESTFILES["test_api.py · test_e2e_pwa.py (Playwright e2e) ·\ntest_inventory_extract.py · test_transcribe_client.py ·\ntest_audio_audit_core.py · smoke_*.py · automation_smoke_*.py"]
  end
  TESTFILES --> API
  TESTFILES --> DATA
  TESTFILES --> EXTRACT
  TESTFILES --> TRANSCRIBE
  TESTFILES --> AUDIOCORE
  TESTFILES --> RUNAUTO
