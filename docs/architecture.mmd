%% docs/architecture.mmd — this repo's own internal structure.
%% Hand-authored, not generated — unlike a fleet-wide crawled map, this
%% repo's own internal shape is semantic and can't be scraped the same way.
%% Update this diagram in the same PR as any material structural change (a
%% new mode/route, a module moved, a new external dependency wired in) —
%% same anti-staleness contract as this repo's own `.fleet.toml` `description`
%% field. See ferraroroberto/fleet-config#256 for the general convention.

flowchart TB
  subgraph frontend["Primary surface — FastAPI + vanilla-JS PWA (:8502)"]
    STATIC["app/static/\nindex.html · styles.css · generated PWA icons\n_vendored/ (fleet nav, icons, card, disclosure, modal, switch, empty-state)"]
    APPJS["app/static/app.js\norchestrator: render() mode routing, delegated listeners, boot"]
    JSMODULES["app/static/modules/ (ES modules, no bundler)\ncore (state + render mediator) · dom · media · api\ninventory · shopping · automation · email · audio · search"]
    API["app/api.py\ncomposition root: lifespan, middleware, static mount, router includes"]
    ROUTERS["app/routers/ — one APIRouter per concern\nsystem (shell, version, manifest, login, access, actions)\ninventory · automation · product_search · audio · voice · email"]
    APICOMMON["app/api_common.py\ndata-layer → HTTP translation (lock/file errors → status codes),\ninventory payload builder shared by every router"]
    AUDIOHUB["app/audio_hub.py\nvoice-transcriber session proxy + whisper transcode/transcribe"]
    STATICFILES["app/static_files.py\nCachingStaticFiles (per-suffix cache policy, JS import stamping) + BUILD_INFO"]
    MW["app/middleware.py\nBearerTokenMiddleware"]
    RUNNER["app/automation_runner.py\nstreams automation.run_automation subprocess into the app"]
    PSRUNNER["app/product_search_runner.py\nspawns automation.product_search, captures its JSON stdout"]
    SUBPROC["app/subprocess_plumbing.py\nshared spawn/drain/stop plumbing (#95)"]
    POLLER["app/email_poller.py\nbackground confirmation-email poll loop + check log"]
    VERSIONING["src/static_versioning.py\nBuildInfo: fleet asset hash, JS/HTML import stamping, git SHA"]
    APPJS --> JSMODULES
    STATIC --> APPJS
    APPJS --> API
    JSMODULES --> API
    MW --> API
    API --> ROUTERS
    API --> STATICFILES
    STATICFILES --> VERSIONING
    ROUTERS --> APICOMMON
    ROUTERS --> AUDIOHUB
    AUDIOHUB --> APICOMMON
    ROUTERS --> RUNNER
    ROUTERS --> PSRUNNER
    RUNNER --> SUBPROC
    PSRUNNER --> SUBPROC
    ROUTERS --> POLLER
  end

  subgraph legacy["Legacy surface — Streamlit (:8501)"]
    APPPY["app/app.py\npage config, session state, sidebar routing"]
    MODES["audit.py · audio_audit.py · edit_targets.py ·\nedit_item.py · add_item.py · shopping.py · export.py"]
    UIHELP["app/ui_helpers.py\nshared CSS + widgets"]
    APPPY --> MODES
    MODES --> UIHELP
    MODES --> RUNNER
  end

  subgraph datalayer["src/ — UI-free data & business layer"]
    DATA["src/data.py\nconfig load, XLSX read/write,\nsupermarket stats, quantity mutators"]
    AUDIOCORE["src/audio_audit_core.py\ntranscript cleaning, audit-log writer"]
    EXTRACT["src/inventory_extract.py\nLLM match against inventory"]
    VOICECMD["src/voice_command.py\nSpanish voice-command parse (LLM) +\napply + speech replies (home-automation#315)"]
    HUBCLIENT["src/hub_client.py\nshared call_hub_llm() helper (#95)"]
    PRODMATCH["src/product_match.py\nranks store search hits vs the spoken term (display aid, #87)"]
    TRANSCRIBE["src/transcribe_client.py\nwhisper-server client + ffmpeg transcode"]
    NET["src/net.py\nLAN-IP / port-probe helpers"]
    WEBCFG["src/webapp_config.py\ntoken/password remote-access config"]
    GMAILCFG["src/gmail_config.py\nsender whitelist + store mapping + poller settings"]
    NOTIFYCFG["src/notify_config.py + src/notify/\nvendored Telegram notifier (from whatsapp-radar)"]
    SSL["src/gen_ssl_cert.py\nlocal CA + server cert"]
  end
  APICOMMON --> DATA
  ROUTERS --> DATA
  ROUTERS --> AUDIOCORE
  ROUTERS --> EXTRACT
  ROUTERS --> VOICECMD
  EXTRACT --> HUBCLIENT
  VOICECMD --> HUBCLIENT
  VOICECMD --> DATA
  AUDIOHUB --> TRANSCRIBE
  ROUTERS --> NET
  ROUTERS --> WEBCFG
  MODES --> DATA
  MODES --> AUDIOCORE
  MODES --> EXTRACT
  MODES --> TRANSCRIBE
  MODES --> NET
  AUDIOCORE --> DATA

  XLSX[("data/list.xlsx\n(Excel-backed inventory)")]
  DATA --> XLSX

  subgraph cartauto["automation/ — Playwright cart automation"]
    RUNAUTO["run_automation.py\nCLI entrypoint"]
    STOREMODS["mercadona.py · ametller.py\nper-store cart handlers"]
    BROWSER["browser.py\nreal-Chrome launch, dedicated chrome_user_data/ profile"]
    BOOTSTRAP["bootstrap_session.py\none-time interactive store login"]
    READER["grocery_reader.py\nreads shopping-list rows from the inventory"]
    REPORT["report.py / models.py / errors.py\nrun summary, CartItem, typed exceptions"]
    PURCHASELOG["purchase_log.py\nwrites per-store purchase_logs/ JSON after a live run"]
    EMAILCHECK["email_check.py\nconfirmation-email check seam:\nsubject similarity, processed-state idempotency"]
    EMAILPARSERS["email_parsers/ametller.py\ndeterministic per-store item-list parser"]
    ITEMMATCH["item_matching.py\nalias/exact/fuzzy matching vs latest purchase log"]
    PRODSEARCH["product_search.py\nstore product search (Mercadona Algolia +\nAmetller SCAPI), reuses browser.py (#87)"]
    RUNAUTO --> STOREMODS
    STOREMODS --> BROWSER
    BOOTSTRAP --> BROWSER
    RUNAUTO --> READER
    RUNAUTO --> REPORT
    RUNAUTO --> PURCHASELOG
    EMAILCHECK --> EMAILPARSERS
    EMAILCHECK --> ITEMMATCH
    PRODSEARCH --> BROWSER
    PRODSEARCH -.->|reuses SCAPI auth| STOREMODS
  end
  RUNNER --> RUNAUTO
  PSRUNNER --> PRODSEARCH
  PRODSEARCH --> PRODMATCH
  POLLER --> EMAILCHECK
  EMAILCHECK --> GMAILCFG
  EMAILCHECK --> NOTIFYCFG
  ITEMMATCH -.->|latest purchase_logs/ JSON| PURCHASELOG
  READER --> XLSX

  subgraph external["External dependencies (sibling projects, same machine)"]
    HUB["claude-local-calls hub\n127.0.0.1:8000 — Anthropic-shape LLM proxy"]
    WHISPER["whisper-server\n127.0.0.1:8090 — OpenAI-compatible transcription"]
    VOICET["voice-transcriber webapp\n127.0.0.1:8443 — chunked recording/session API"]
    CHROME["Real installed Chrome\n(not bundled Chromium)"]
    CLOUDFLARE["cloudflared named tunnel\n(webapp/cloudflared.yml)"]
    GMAILAPI["Gmail API — read-only scope\n(vendored gmail_readonly/, creds shared with whatsapp-radar)"]
    TELEGRAM["Telegram Bot API\n(order-confirmation alerts)"]
    SCAFFOLD["project-scaffolding\nLucide master + brand_gen icon renderer"]
  end
  HUBCLIENT -->|Anthropic SDK, base_url| HUB
  TRANSCRIBE -->|POST /v1/audio/transcriptions| WHISPER
  AUDIOHUB -->|proxies recording lifecycle| VOICET
  BROWSER --> CHROME
  API -.->|optional public access| CLOUDFLARE
  GMAILCFG -->|gmail_readonly client| GMAILAPI
  NOTIFYCFG --> TELEGRAM
  SCAFFOLD -.->|development-time generated assets| STATIC

  subgraph scripts["scripts/ & webapp/ — setup & remote access"]
    GENTOKEN["gen_token.py / set_password.py\nbearer-token + password auth"]
    TAILCERT["gen_tailscale_cert.py\nTailscale HTTPS cert"]
    TUNNEL["run_named_tunnel.py"]
    GENICONS["gen_icons.py\nPWA · tray · Stream Deck icon family"]
  end
  GENTOKEN --> WEBCFG
  TAILCERT --> SSL
  GENICONS --> STATIC
  SCAFFOLD --> GENICONS

  subgraph tests["tests/ — pytest suite + smoke scripts"]
    TESTFILES["test_api.py · test_e2e_pwa.py (Playwright e2e) ·\ntest_inventory_extract.py · test_transcribe_client.py ·\ntest_audio_audit_core.py · smoke_*.py · automation_smoke_*.py"]
  end
  TESTFILES --> API
